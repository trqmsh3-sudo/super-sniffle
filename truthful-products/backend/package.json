  "description": "Backend API for TruthfulProducts - Unbiased product research platform",
  "main": "server.js",
  "scripts": {
    "start": "node server-unified.js",
    "start:old": "node server-real.js",
    "start:windsurf": "node src/server.js",
    "mock": "node mock-server.js",
    "dev": "nodemon server-unified.js",
    "test": "jest",
    "test-db": "node test-db.js",
    "test-collector": "node test-collector.js",
