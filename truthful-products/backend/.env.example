# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Redis Cache
REDIS_URL=redis://localhost:6379

# AI Service - OpenAI GPT-4o-mini (Cost-Effective!)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Reddit API
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=TruthfulProducts/1.0

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Caching
CACHE_PRODUCT_TTL=21600

# CORS
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=info

# Rainforest API (Amazon Data)
RAINFOREST_API_KEY=your_rainforest_api_key_here

# Google Shopping API (Small Retailers)
GOOGLE_SHOPPING_API_KEY=your_google_shopping_api_key_here
GOOGLE_SHOPPING_CX=your_custom_search_engine_id_here

# Affiliate Programs
AMAZON_AFFILIATE_TAG=clearpick-20
WALMART_AFFILIATE_ID=your_walmart_affiliate_id
BESTBUY_AFFILIATE_ID=your_bestbuy_affiliate_id

# Rainforest API (Amazon Data)
RAINFOREST_API_KEY=your_rainforest_api_key_here

# Google Shopping API (Small Retailers)
GOOGLE_SHOPPING_API_KEY=your_google_shopping_api_key_here
GOOGLE_SHOPPING_CX=your_custom_search_engine_id_here

# Affiliate Programs
AMAZON_AFFILIATE_TAG=clearpick-20
WALMART_AFFILIATE_ID=your_walmart_affiliate_id
BESTBUY_AFFILIATE_ID=your_bestbuy_affiliate_id
